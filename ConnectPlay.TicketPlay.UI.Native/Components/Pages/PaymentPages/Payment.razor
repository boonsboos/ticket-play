@page "/payment"

<div class="container mt-5">
    <h2 class="mb-5 text-center">@AppResources.Payment_Title</h2>

    <div class="mb-4 text-center">
        <div class="form-check form-check-inline">
            <input class="form-check-input"
                   type="radio"
                   id="ideal"
                   name="paymentMethod"
                   @onchange="() => SetPaymentMethod(PaymentMethod.Ideal)"
                   checked="@(_selectedMethod == PaymentMethod.Ideal)">
                <label class="form-check-label fs-5" for="ideal">iDEAL/Wero</label>
            </div>

            <div class="form-check form-check-inline">
                <input class="form-check-input"
                       type="radio"
                       id="credit"
                       name="paymentMethod"
                       @onchange="() => SetPaymentMethod(PaymentMethod.CreditCard)"
                       checked="@(_selectedMethod == PaymentMethod.CreditCard)">
                    <label class="form-check-label fs-5" for="credit">Credit Card</label>
                </div>
            </div>

            <div class="card p-4 shadow-sm mx-auto" style="max-width: 500px;">
                @if (_selectedMethod == PaymentMethod.Ideal)
                {
                    <div class="mb-3">
                        <label class="form-label fs-6">@AppResources.Payment_SelectBank</label>
                        <select @bind="_selectedBank" class="form-select form-select-lg">
                            <option value="">@AppResources.Payment_BankPlaceholder</option>
                            <option value="Rabo">Rabo</option>
                            <option value="ING">ING</option>
                            <option value="SNS">SNS</option>
                        </select>
                    </div>
                    <button class="btn btn-success btn-lg w-100"
                            @onclick="PayAsync"
                            disabled="@string.IsNullOrEmpty(_selectedBank)">
                        @AppResources.Payment_PayIdeal
                    </button>
                }
                else if (_selectedMethod == PaymentMethod.CreditCard)
                {
                    <EditForm Model="_creditCardModel" OnValidSubmit="PayAsync">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label fs-6">@AppResources.Payment_CardFormName</label>
                            <InputText @bind-Value="_creditCardModel.Name" class="form-control form-control-lg" />
                            <CreditCardValidationMessage For="@(() => _creditCardModel.Name)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fs-6">@AppResources.Payment_CardFormNumber</label>
                            <InputText @bind-Value="_creditCardModel.Number" class="form-control form-control-lg" />
                            <CreditCardValidationMessage For="@(() => _creditCardModel.Number)" />
                        </div>
                        <div class="row mb-3">
                            <div class="col">
                                <label class="form-label fs-6">@AppResources.Payment_CardFormExpiry</label>
                                <InputText @bind-Value="_creditCardModel.Expiry" class="form-control form-control-lg" />
                                <CreditCardValidationMessage For="@(() => _creditCardModel.Expiry)" />
                            </div>
                            <div class="col">
                                <label class="form-label fs-6">@AppResources.Payment_CardFormCVC</label>
                                <InputText @bind-Value="_creditCardModel.CVC" class="form-control form-control-lg" />
                                <CreditCardValidationMessage For="@(() => _creditCardModel.CVC)" />
                            </div>
                        </div>
                        <button type="submit" class="btn btn-success btn-lg w-100"
                                disabled="@(!IsCreditCardFormValid)">
                            @AppResources.Payment_PayCreditCard
                        </button>
                    </EditForm>
                }
            </div>
        </div>