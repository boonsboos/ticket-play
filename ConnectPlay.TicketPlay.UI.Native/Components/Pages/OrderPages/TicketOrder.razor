@page "/order/tickets"

@using ConnectPlay.TicketPlay.Models
@using ConnectPlay.TicketPlay.UI.Native.Components.Elements;

<div class="container mt-4 col-md-6 offset-md-3 col-sm-12 offset-sm-0 d-flex flex-column justify-content-center align-items-center">

    <h2 class="text-center">@AppResources.OrderTickets_Title</h2>

    @* little screening overview *@
    <div class="border border-secondary-subtle rounded p-3 mt-5 w-100">
        <div class="d-flex justify-content-between align-items-center">
            <p class="fw-semibold mb-0">@AppResources.OrderTickets_Movie</p>
            <p class="text-muted mb-0">@DisplayTitle</p>
        </div>
        <div class="d-flex justify-content-between align-items-center">
            <p class="fw-semibold mb-0">@AppResources.OrderTickets_Hall</p>
            <p class="text-muted mb-0">@Screening.Hall.HallNumber</p>
        </div>
        <div class="d-flex justify-content-between align-items-center">
            <p class="fw-semibold mb-0">@AppResources.OrderTickets_Time</p>
            <p class="text-muted mb-0">@Screening.StartTime.ToLocalTime().ToString("HH:mm")</p>
        </div>
        @if (Screening.Hall.Has3DProjector)
        {
            <div class="d-flex justify-content-between align-items-center">
                <p class="fw-semibold mb-0">3D:</p>
                <p class="text-muted mb-0">@AppResources.OrderTickets_3DYes</p>
            </div>
        }
    </div>

    <div class="d-flex flex-column gap-3 mt-4 w-100">
        @foreach (var ticketType in Enum.GetValues<TicketType>())
        {
            <div class="border border-secondary-subtle rounded p-3 d-flex">
                <div class="d-flex flex-column align-items-start justify-content-center">
                    <h4 class="fw-semibold text-body mb-0">
                        @(ticketType switch
                        {
                            TicketType.Regular => AppResources.OrderTickets_Regular,
                            TicketType.Child => AppResources.OrderTickets_Child,
                            TicketType.Student => AppResources.OrderTickets_Student,
                            TicketType.Senior => AppResources.OrderTickets_Senior,
                            _ => ticketType.ToString()
                        })
                    </h4>
                    @if (IsPreview)
                    {
                        <p class="text-muted mb-0">
                            <span class="text-decoration-line-through">
                                @((orderFlowService.GetPrice(ticketType) + 2.5m).ToString("C"))
                            </span>
                            <span>@orderFlowService.GetPrice(ticketType).ToString("C")</span>
                        </p>
                    }
                    else
                    {
                        <p class="text-muted mb-0">@orderFlowService.GetPrice(ticketType).ToString("C")</p>
                    }
                </div>

                @* counter *@
                <div class="d-flex flex-row align-items-center gap-2 ms-auto">
                    <button class="btn btn-outline-secondary" @onclick="() => DecreaseTicket(ticketType)">
                        <i class="bi bi-dash"></i>
                    </button>
                    <p class="mb-0">@(Tickets.FirstOrDefault(t => t.Type == ticketType)?.Count ?? 0)</p>
                    <button class="btn btn-outline-secondary" @onclick="() => IncreaseTicket(ticketType)">
                        <i class="bi bi-plus"></i>
                    </button>
                </div>
            </div>
        }
    </div>

    <div class="d-flex flex-column w-100">
        <ArrangementSelector @ref="arrangementSelector" />
    </div>

    <div class="container d-flex justify-content-between m-3">
        <button class="btn btn-outline-primary" @onclick="ToMovie">@AppResources.OrderTickets_Back</button>
        <button class="btn btn-primary" @onclick="HandlePlaceOrder" disabled="@(!Tickets.Any())">@AppResources.OrderTickets_Next</button>
    </div>
</div>
