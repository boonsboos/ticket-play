@page "/"
@rendermode InteractiveServer

<PageTitle>Ticket & Play</PageTitle>

<div class="container d-flex flex-column justify-content-center gap-2">
    <a href="/movie/today">
        <div class="card col-4 offset-4">
            <div class="card-body d-flex justify-content-center">
                <!-- TODO: add flags to indicate different language paths -->
                <h2>Koop je kaartjes</h2>
            </div>
        </div>
    </a>

    <div class="d-flex flex-column gap-2 col-4 offset-4 justify-content-between mt-5">
        <h4 class="text-center">Online al besteld? Print hier je tickets!</h4>
        @if (orderDoesNotExist)
        {
            <div class="alert alert-danger" role="alert">
                <p class="text-center">Bestelling niet gevonden. Zorg ervoor dat je de bestelcode goed in hebt gevuld!</p>
            </div>
        }
        <div class="d-flex flex-row gap-2 justify-content-center">
            <div class="input-group">
            <InputText @bind-Value="orderCode" class="form-control" placeholder="Bestelcode..."/>
            <button 
                class="btn btn-primary" 
                disabled="@(!IsOrderCodeValid())" 
                @onclick="TryPrintAsync"
            >
                <i class="bi bi-printer"></i>
            </button>
            </div>
        </div>
    </div>
</div>
