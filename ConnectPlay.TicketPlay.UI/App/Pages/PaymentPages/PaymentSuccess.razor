@page "/payment/success"

@using ConnectPlay.TicketPlay.UI.App.Components.Base

@layout MainLayout

@inherits TranslatableComponent;

<PageTitle>@T["paymentSuccess.pageTitle"]</PageTitle>

<div class="d-flex justify-content-center align-items-center h-100 flex-column mt-5 pt-5">
    <div class="text-center">

        <h1>@T["paymentSuccess.title"]</h1>

        <h2>@websiteService.Movie?.Title</h2>

        <p>@T["paymentSuccess.rememberTickets"]</p>

        <img class="tickets" src="@websiteService.Movie?.PosterUrl" alt="@T["paymentSuccess.posterAlt"]" />
    </div>

    @if (websiteService.CurrentOrderId is not null)
    {
        <div class="row">
            <a class="btn btn-primary mt-3" href="@GetTicketFileUrl()" target="_blank" rel="noopener noreferrer">
                <i class="bi bi-printer"></i>&nbsp;@T["paymentSuccess.printTickets"]
            </a>
        </div>
    }

    <div class="d-flex gap-3 mt-5">
        <ShareButton Platform="Twitter" Text="@GetShareMessage()">
            @T["paymentSuccess.shareOn"] Twitter
        </ShareButton>
        <ShareButton Platform="WhatsApp" Text="@GetShareMessage()">
            @T["paymentSuccess.shareOn"] WhatsApp
        </ShareButton>
        <ShareButton Platform="Telegram" Text="@GetShareMessage()">
            @T["paymentSuccess.shareOn"] Telegram
        </ShareButton>
        <ShareButton Platform="Reddit" Text="@GetShareMessage()">
            @T["paymentSuccess.shareOn"] Reddit
        </ShareButton>
    </div>
</div>
