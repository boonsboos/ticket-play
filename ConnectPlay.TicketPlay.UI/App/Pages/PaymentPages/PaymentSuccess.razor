@page "/payment/success"
@layout MainLayout

<div class="d-flex justify-content-center align-items-center vh-100 flex-column">
    <div class="text-center">

        <h1>Veel plezier!</h1>

        <h2>@websiteService.Movie?.Title</h2>

        <p>Vergeet niet je kaartjes mee te nemen.</p>

        <img class="tickets" src="@websiteService.Movie?.PosterUrl" alt="Film poster" />
    </div>

    @if (websiteService.CurrentOrderId is not null)
    {
        <div class="row">
            <a class="btn btn-primary mt-3" href="@GetTicketFileUrl()" target="_blank" rel="noopener noreferrer">
                <i class="bi bi-printer"></i>&nbsp;Print tickets
            </a>
        </div>
    }
</div>