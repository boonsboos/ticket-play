@* this url is the url in the header *@
@page "/"

@using ConnectPlay.TicketPlay.UI.App.Components.Base

@layout MainLayout

@inherits TranslatableComponent;

@rendermode InteractiveServer

<PageTitle>@T["home.pageTitle"]</PageTitle>

<h1>@T["home.title"]</h1>

@if (isLoading)
{
    <p>@T["home.loading"]</p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <p class="text-danger">@T[errorMessage]</p>
}
else if (!movies.Any())
@* Any() checks if there is minimum 1 element*@
{
    <p>@T["home.noMovies"]</p>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-4">
        @foreach (var movie in movies)
        {
            <div class="col" @onclick="() => ToMovie(movie.Id)">
                <div class="card h-100 p-3">
                    <img src="@movie.PosterUrl" alt="@movie.Title" class="img-fluid mb-2" />
                    <h5 class="mb-1">@movie.Title</h5>
                    <p class="text-muted mb-2">@movie.Genre</p>

                    <div class="d-flex gap-2 flex-wrap">
                        @{
                            // Materialize up to 4 screening times to avoid multiple enumeration
                            var screeningTimes = movie.ScreeningTimes.Take(4).ToList();
                            var visibleTimes = screeningTimes.Take(3);
                            var hasMoreScreenings = screeningTimes.Count > 3;
                        }
                        @foreach (var startTime in visibleTimes)
                        {
                            @if (startTime < DateTimeOffset.Now)
                            {
                                <span class="badge bg-secondary">@startTime.ToLocalTime().ToString("HH:mm")</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">@startTime.ToLocalTime().ToString("HH:mm")</span>
                            }
                            
                        }

                        @if (hasMoreScreenings)
                        {
                            <span class="badge bg-secondary">@T["home.seeMore"]</span>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>