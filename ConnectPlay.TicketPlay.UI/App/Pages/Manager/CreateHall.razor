@page "/manager/create-hall"

@using ConnectPlay.TicketPlay.UI.App.Components.Base

@inherits TranslatableComponent;

@rendermode InteractiveServer

<PageTitle>@T["createHall.pageTitle"]</PageTitle>

<div class="container my-4 col-8">
    <h3 class="mb-4">@T["createHall.title"]</h3>
    <div class="card shadow-sm">
        <div class="card-body">
            <EditForm Model="@form" OnValidSubmit="HandleSubmit" FormName="CreateHallForm">
                <ValidationSummary />

                <div class="row g-3 mb-4">
                    <div class="col-md-9">
                        <label class="form-label">@T["createHall.hallNumber"]</label>
                        <InputNumber class="form-control" @bind-Value="form.HallNumber" />
                    </div>

                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check">
                            <InputCheckbox class="form-check-input" @bind-Value="form.Has3DProjector" />
                            <label class="form-check-label">
                                @T["createHall.has3DProjector"]
                            </label>
                        </div>
                    </div>
                </div>

                <div class="d-flex align-items-center justify-content-between mb-3 border-bottom">
                    <h5 class="">@T["createHall.rowsConfiguration"]</h5>

                    <button type="button" class="btn btn-sm btn-outline-primary mb-2" @onclick="AddRow">
                        + @T["createHall.addRow"]
                    </button>
                </div>

                <div class="vstack gap-3 mb-4">
                    @for (var i = 0; i < form.Rows.Count; i++)
                    {
                        var rowIndex = i;

                        <div class="border rounded p-3 bg-light-subtle">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <strong>@T["createHall.row"] @(rowIndex + 1)</strong>

                                <button type="button" class="btn btn-sm btn-outline-danger"
                                        disabled="@(form.Rows.Count == 1)" @onclick="() => RemoveRow(rowIndex)">
                                    @T["createHall.remove"]
                                </button>
                            </div>

                            <label class="form-label">@T["createHall.seatsInRow"]</label>
                            <InputNumber class="form-control" @bind-Value="form.Rows[rowIndex]"
                                         @bind-Value:after="EnsureWheelchairSelectionValid" min="1" />
                        </div>
                    }
                </div>

                <hr />
                <h5 class="mb-3 border-bottom pb-2">@T["createHall.wheelchairSeat"]</h5>
                <div class="card bg-light border-0 mb-4">
                    <div class="card-body">
                        <p class="text-muted small mb-3">
                            @T["createHall.wheelchairHelp"]
                        </p>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">@T["createHall.row"]</label>
                                <InputSelect class="form-select" @bind-Value="form.WheelchairRow"
                                             @bind-Value:after="EnsureWheelchairSelectionValid">
                                    <option value="0">@T["createHall.selectRow"]</option>
                                    @for (var r = 1; r <= form.Rows.Count; r++)
                                    {
                                        <option value="@r">@r</option>
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">@T["createHall.seat"]</label>
                                <InputSelect class="form-select" @bind-Value="form.WheelchairSeat">
                                    <option value="0">@T["createHall.selectSeat"]</option>
                                    @{
                                        var maxSeat = SeatsInSelectedWheelchairRow();
                                        for (var s = 1; s <= maxSeat; s++)
                                        {
                                            <option value="@s">@s</option>
                                        }
                                    }
                                </InputSelect>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary px-4" disabled="@isSubmitting">
                        @T["createHall.submit"]
                    </button>
                </div>
            </EditForm>

            @if (showToast)
            {
                <div class="toast-container position-fixed bottom-0 end-0 p-3">
                    <div class="toast show align-items-center text-white @toastColor border-0">
                        <div class="d-flex">
                            <div class="toast-body">
                                @toastMessage
                            </div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="HideToast">
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>