@page "/manager/create-screening"

@using ConnectPlay.TicketPlay.UI.App.Components.Base

@inherits TranslatableComponent;

@rendermode InteractiveServer

<PageTitle>@T["createScreening.pageTitle"]</PageTitle>

<div class="container my-4" style="max-width: 1200px;">
    <h3 class="mb-4">@T["createScreening.title"]</h3>
    <div class="card shadow-sm">
        <div class="card-body">
            <EditForm Model="@form" OnValidSubmit="HandleSubmit" FormName="CreateScreening">

                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label">@T["createScreening.movie"]</label>
                        <InputSelect class="form-select" @bind-Value="form.MovieId">
                            <option value="0">@T["createScreening.selectMovie"]</option>
                            @foreach (var m in Movies)
                            {
                                <option value="@m.Id">@m.Title</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">@T["createScreening.hall"]</label>
                        <InputSelect class="form-select" @bind-Value="form.HallId">
                            <option value="0">@T["createScreening.selectHall"]</option>
                            @foreach (var h in Halls)
                            {
                                <option value="@h.Id">@T["createScreening.hallOption"] @h.HallNumber</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label">@T["createScreening.Date"]</label>
                        <InputDate class="form-control" @bind-Value="form.TimeDate" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">@T["createScreening.time"]</label>
                        <InputSelect class="form-select" @bind-Value="form.TimeHour">
                            @for (int h = 9; h <= 21; h++)
                            {
                                <option value="@h">@h:00</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <label for="sneakPreview" class="form-label mb-0">@T["createScreening.sneakPreview"]</label>
                        @if (IsSneakPreviewDisabled)
                        {
                            <span class="sneak-preview-blocked"
                                  title="@T["createScreening.sneakPreviewBlocked"]">
                                ✕
                            </span>
                        }
                        else
                        {
                            <InputCheckbox id="sneakPreview"
                                           class="form-check-input mt-0"
                                           @bind-Value="form.SneakPreview" />
                        }
                    </div>

                    <button type="submit" class="btn btn-primary px-4" disabled="@isSubmitting">
                        @T["createScreening.submit"]
                    </button>
                </div>

                @if (showToast)
                {
                    <div class="toast-container position-fixed bottom-0 end-0 p-3">
                        <div class="toast show align-items-center text-white @toastColor border-0">
                            <div class="d-flex">
                                <div class="toast-body">@toastMessage</div>
                                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="HideToast"></button>
                            </div>
                        </div>
                    </div>
                }
            </EditForm>
        </div>
    </div>
</div>