@using ConnectPlay.TicketPlay.UI.App.Components.Base

@inherits TranslatableComponent

<div class="d-flex justify-content-center mt-5 col-12">
    <div class="card shadow-sm w-100">
        <div class="card-body text-center">
            <h4 class="mb-4 fw-bold">Arrangementen</h4>

            <p>Bestel hier je drankje of snack, wij zorgen dat het bij je stoel staat wanneer de film begint!</p>

            <div class="accordion">
                <details class="accordion-item p-3">
                    <summary class="accordion-header d-flex justify-content-between py-3">
                        <h5 class="text-start fw-bold">Popcorn</h5>
                        <i class="bi bi-arrow-down"></i>
                    </summary>
                    <hr />
                    @foreach (var item in PopcornOptions)
                    {
                        <div class="row g-3 mb-3 align-items-center justify-content-center">
                            <div class="col-5 text-start">@item.Name</div>
                            <div class="col-2">@item.Price.ToString("C")</div>
                            <div class="col-2">
                                <InputNumber class="form-control mx-auto" style="max-width: 80px;" min="0" @bind-Value="item.Quantity" />
                            </div>
                            <div class="col-3">Subtotaal: @((item.Quantity * item.Price).ToString("C"))</div>
                        </div>
                    }
                </details>

                <details class="accordion-item p-3">
                    <summary class="accordion-header d-flex justify-content-between py-3">
                        <h5 class="text-start fw-bold">Dranken</h5>
                        <i class="bi bi-arrow-down"></i>
                    </summary>
                    <hr />
                    @foreach (var item in DrinkOptions)
                    {
                        <div class="row g-3 mb-3 align-items-center justify-content-center">
                            <div class="col-5 text-start">@item.Name</div>
                            <div class="col-2">@item.Price.ToString("C")</div>
                            <div class="col-2">
                                <InputNumber class="form-control mx-auto" style="max-width: 80px;" min="0" @bind-Value="item.Quantity" />
                            </div>
                            <div class="col-3">Subtotaal: @((item.Quantity * item.Price).ToString("C"))</div>
                        </div>
                    }
                </details>

                <details class="accordion-item p-3">
                    <summary class="accordion-header d-flex justify-content-between py-3">
                        <h5 class="text-start fw-bold">Combi</h5>
                        <i class="bi bi-arrow-down"></i>
                    </summary>
                    <hr />
                    @foreach (var combi in CombiSelections)
                    {
                        <div class="row g-3 mb-3 align-items-center justify-content-center">
                            <div class="col-5 text-start">Medium Popcorn + @combi.Drink.Name</div>
                            <div class="col-2">@combi.PriceWithDiscount.ToString("C")</div>
                            <div class="col-2">
                                <InputNumber class="form-control mx-auto" style="max-width: 80px;" min="0" @bind-Value="combi.Quantity" />
                            </div>
                            <div class="col-3">Subtotaal: @((combi.Quantity * combi.PriceWithDiscount).ToString("C"))</div>
                        </div>
                    }
                </details>
            </div>

            <div class="alert alert-light border mt-4 text-start">
                <h6 class="mb-3 text-center">Totaal overzicht</h6>
                <ul class="list-unstyled">
                    @foreach (var item in PopcornOptions.Where(p => p.Quantity > 0))
                    {
                        <li>@item.Name x @item.Quantity = @((item.Quantity * item.Price).ToString("C"))</li>
                    }
                    @foreach (var item in DrinkOptions.Where(d => d.Quantity > 0))
                    {
                        <li>@item.Name x @item.Quantity = @((item.Quantity * item.Price).ToString("C"))</li>
                    }
                    @foreach (var combi in CombiSelections.Where(c => c.Quantity > 0))
                    {
                        <li>Medium Popcorn + @combi.Drink.Name x @combi.Quantity = @((combi.Quantity * combi.PriceWithDiscount).ToString("C"))</li>
                    }
                </ul>
                <strong>Totaal: @(TotalPrice.ToString("C"))</strong>
            </div>

            <div class="d-flex justify-content-center mt-3 gap-2">
                <button class="btn btn-primary" @onclick="SaveSelection">Opslaan</button>
                @if (SavedSelections.Any())
                {
                    <button class="btn btn-danger" @onclick="ClearSelection">Verwijder selectie</button>
                }
            </div>

            @if (ShowToast)
            {
                <div class="alert alert-@ToastType alert-dismissible fade show mt-3" role="alert">
                    @ToastMessage
                    <button type="button" class="btn-close" @onclick="() => ShowToast = false"></button>
                </div>
            }
        </div>
    </div>
</div>