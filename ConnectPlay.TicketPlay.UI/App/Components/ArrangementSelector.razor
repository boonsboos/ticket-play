@namespace ConnectPlay.TicketPlay.UI.App.Components

<div class="d-flex justify-content-center mt-5">
    <div class="card shadow-sm" style="max-width: 700px; width: 100%;">
        <div class="card-body text-center">
            <h5 class="mb-4 fw-bold">Arrangementen</h5>

            <h6 class="text-start mb-3 fw-bold">Popcorn</h6>
            @foreach (var item in PopcornOptions)
            {
                <div class="row g-3 mb-3 align-items-center justify-content-center">
                    <div class="col-5 text-start">@item.Name</div>
                    <div class="col-2">€@item.Price</div>
                    <div class="col-2">
                        <InputNumber class="form-control mx-auto" style="max-width: 80px;" min="0" @bind-Value="item.Quantity" />
                    </div>
                    <div class="col-3">Subtotaal: €@(Math.Round((item.Quantity ?? 0) * item.Price, 2))</div>
                </div>
            }

            <h6 class="mt-4 mb-3 text-start fw-bold">Dranken</h6>
            @foreach (var item in DrinkOptions)
            {
                <div class="row g-3 mb-3 align-items-center justify-content-center">
                    <div class="col-5 text-start">@item.Name</div>
                    <div class="col-2">€@item.Price</div>
                    <div class="col-2">
                        <InputNumber class="form-control mx-auto" style="max-width: 80px;" min="0" @bind-Value="item.Quantity" />
                    </div>
                    <div class="col-3">Subtotaal: €@(Math.Round((item.Quantity ?? 0) * item.Price, 2))</div>
                </div>
            }

            <h6 class="mt-4 mb-3 text-start fw-bold">Combi (Medium Popcorn + Drink, 10% korting)</h6>
            @foreach (var combi in CombiSelections)
            {
                <div class="row g-3 mb-3 align-items-center justify-content-center">
                    <div class="col-5 text-start">Medium Popcorn + @combi.Drink.Name</div>
                    <div class="col-2">€@combi.PriceWithDiscount</div>
                    <div class="col-2">
                        <InputNumber class="form-control mx-auto" style="max-width: 80px;" min="0" @bind-Value="combi.Quantity" />
                    </div>
                    <div class="col-3">Subtotaal: €@(Math.Round((combi.Quantity ?? 0) * combi.PriceWithDiscount, 2))</div>
                </div>
            }

            <div class="alert alert-light border mt-4 text-start">
                <h6 class="mb-3 text-center">Totaal overzicht</h6>
                <ul class="list-unstyled">
                    @foreach (var item in PopcornOptions.Where(p => (p.Quantity ?? 0) > 0))
                    {
                        <li>@item.Name x @item.Quantity = €@(Math.Round((item.Quantity ?? 0) * item.Price, 2))</li>
                    }
                    @foreach (var item in DrinkOptions.Where(d => (d.Quantity ?? 0) > 0))
                    {
                        <li>@item.Name x @item.Quantity = €@(Math.Round((item.Quantity ?? 0) * item.Price, 2))</li>
                    }
                    @foreach (var combi in CombiSelections.Where(c => (c.Quantity ?? 0) > 0))
                    {
                        <li>Medium Popcorn + @combi.Drink.Name x @combi.Quantity = €@(Math.Round((combi.Quantity ?? 0) * combi.PriceWithDiscount, 2))</li>
                    }
                </ul>
                <strong>Totaal: €@TotalPrice</strong>
            </div>

            <div class="d-flex justify-content-center mt-3 gap-2">
                <button class="btn btn-primary" @onclick="SaveSelection">Opslaan</button>
                @if (SavedSelections.Any())
                {
                    <button class="btn btn-danger" @onclick="ClearSelection">Verwijder selectie</button>
                }
            </div>

            @if (ShowToast)
            {
                <div class="alert alert-@ToastType alert-dismissible fade show mt-3" role="alert">
                    @ToastMessage
                    <button type="button" class="btn-close" @onclick="() => ShowToast = false"></button>
                </div>
            }

            @if (SavedSelections.Any())
            {
                <div class="mt-3 text-start">
                    <h6>Opgeslagen selectie:</h6>
                    <ul>
                        @foreach (var item in SavedSelections)
                        {
                            <li>@item</li>
                        }
                    </ul>
                </div>
            }
        </div>
    </div>
</div>