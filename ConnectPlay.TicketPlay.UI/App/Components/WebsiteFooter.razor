@using ConnectPlay.TicketPlay.UI.App.Components.Base

@inherits TranslatableComponent

@* This Is is where the website footer content goes *@
@* Bootstrap grid layout goes from container -> row -> col *@
@rendermode InteractiveServer

<footer class="text-white py-4" style="background: linear-gradient(#650096, #4B006E);">
    <div class="container">
        <div class="row justify-content-center text-center">

            <div class="col-md-2 text-start">
                <strong>@T["footer.address"]:</strong><br>
                Hogeschoollaan 1<br>
                4818 CR Breda
            </div>

            <div class="col-md-4">
                <iframe title="Google Maps location"
                        src="https://www.google.com/maps?q=Hogeschoollaan+1+Breda+Netherlands&output=embed"
                        width="80%"
                        height="100%"
                        style="border:0; border-radius:8px;">
                </iframe>
            </div>

            <div class="col-md-3 text-start">
                <strong>Socials:</strong><br>

                <a href="https://facebook.com" target="_blank" class="text-white me-3">
                    <i class="bi bi-facebook fs-4"></i>
                </a>

                <a href="https://wa.me/31612345678" target="_blank" class="text-white me-3">
                    <i class="bi bi-whatsapp fs-4"></i>
                </a>

                <a href="https://instagram.com" target="_blank" class="text-white">
                    <i class="bi bi-instagram fs-4"></i>
                </a>
            </div>

            <div class="col-md-3 text-start">
                <strong>@T["footer.newsletter.title"]</strong>
                <EditForm Model="form" OnValidSubmit="HandleSubmit" FormName="CreateSubscriberFormFooter">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="row mb-2">
                        <div class="col-8">
                            <InputText class="form-control form-control-sm my-1" @bind-Value="form.Name" placeholder="@T["footer.newsletter.namePlaceholder"]" />
                        
                            <InputText class="form-control form-control-sm my-1" @bind-Value="form.Email" placeholder="@T["footer.newsletter.emailPlaceholder"]" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-light btn-sm" disabled="@isSubmitting">@T["footer.newsletter.submit"]</button>
                </EditForm>
            </div>
        </div>
    </div>

    @if (showToast)
    {
        <div class="position-fixed bottom-0 end-0 p-3">
            <div class="alert @toastColor alert-dismissible fade show mb-0" role="alert">
                @toastMessage
                <button type="button"
                        class="btn-close"
                        aria-label="Close"
                        @onclick="() => showToast = false">
                </button>
            </div>
        </div>
    }
</footer>