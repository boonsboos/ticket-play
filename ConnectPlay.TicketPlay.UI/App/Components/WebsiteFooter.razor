@* This Is is where the website footer content goes *@
@* Bootstrap grid layout goes from container -> row -> col *@
@rendermode InteractiveServer

<footer class="text-white py-4" style="background: linear-gradient(#650096, #4B006E);">
    <div class="container">
        <div class="row justify-content-center text-center">

            <div class="col-md-4 text-start">
                <strong>Adres:</strong><br>
                Dorpsmanstraat 88<br>
                5258 XX Straatmansdorp
            </div>

            <div class="col-md-4">
                <strong>Socials:</strong><br>

                <a href="https://facebook.com" target="_blank" class="text-white me-3">
                    <i class="bi bi-facebook fs-4"></i>
                </a>

                <a href="https://wa.me/31612345678" target="_blank" class="text-white me-3">
                    <i class="bi bi-whatsapp fs-4"></i>
                </a>

                <a href="https://instagram.com" target="_blank" class="text-white">
                    <i class="bi bi-instagram fs-4"></i>
                </a>
            </div>

            <div class="col-md-4">
                <EditForm Model="model" OnValidSubmit="HandleValidSubmit" FormName="CreateSubscriberForm">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <InputTextArea class="form-control" @bind-Value="model.name" />
                    <InputTextArea class="form-control" @bind-Value="model.email" />
                </EditForm>
            </div>
        </div>
    </div>
</footer>