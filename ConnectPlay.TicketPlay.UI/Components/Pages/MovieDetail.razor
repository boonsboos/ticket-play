@page "/movie/{Id:int}"

@if (Movie == null)
{
    <div class="container mt-4 text-center">
        <p>Loading movie...</p>
    </div>
}
else
{
    <div class="container mt-4 d-flex justify-content-center">
        <div class="card movie-card mb-4">
            <div class="row g-0 justify-content-center align-items-start mb-4">
                <div class="col-md-4 d-flex justify-content-center p-3">
                    <img src="@Movie.PosterUrl" alt="@Movie.Title" class="img-fluid" />
                </div>
                <div class="col-md-8 d-flex flex-column justify-content-start p-4 card-body">
                    <h2 class="card-title">@Movie.Title</h2>
                    <p class="text-muted mb-2">
                        @Movie.Genre • @Movie.Duration min • @Movie.MinimumAge+
                    </p>
                    @if (!string.IsNullOrWhiteSpace(Movie.Tags))
                    {
                        <div class="mb-3">
                            @foreach (var tag in Movie.Tags.Split(','))
                            {
                                <span class="badge me-1">@tag.Trim()</span>
                            }
                        </div>
                    }
                    <p class="card-text">@Movie.Description</p>
                </div>
            </div>
            <div class="showtime-section text-center">
                <h5 class="mb-3">Voorstellingen</h5>
                <div class="d-flex justify-content-center flex-wrap gap-3">
                </div>
            </div>
        </div>
    </div>
    <div class="container nav-buttons" style="max-width: 1000px;">
        <button class="btn btn-outline-secondary">
            ← Ga terug
        </button>
        <button class="btn-next">
            Volgende →
        </button>
    </div>
}