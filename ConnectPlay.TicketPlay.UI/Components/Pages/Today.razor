@* this url is the url in the header *@
@page "/movie/today"

<h1>Films van vandaag</h1>

@if (isLoading)
{
    <p>Films worden geladen!</p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <p class="text-danger">@errorMessage</p>
}
else if (!movies.Any()) @* Any() checks if there is minimum 1 element*@
{
    <p>Er zijn vandaag geen films meer gepland.</p>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-4">
        @foreach (var movie in movies)
        {
            <div class="col">
                <div class="card h-100 p-3">
                    <img src="@movie.PosterUrl" alt="@movie.Title" class="img-fluid mb-2" />
                    <h5 class="mb-1">@movie.Title</h5>
                    <p class="text-muted mb-2">@movie.Genre</p>

                    <div class="d-flex gap-2 flex-wrap">
                        @foreach (var startTime in movie.ScreeningTimes.Take(3))
                        {
                            <span class="badge bg-primary">@startTime.ToLocalTime().ToString("HH:mm")</span>
                        }

                        @if (movie.ScreeningTimes.Count() > 3)
                        {
                            <span class="badge bg-secondary">Zie meer</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}